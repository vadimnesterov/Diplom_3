# Normalize line endings to LF in the repository; check out as-is on all platforms
* text=auto eol=lf

# Force these file types to always use LF
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files — do not touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
